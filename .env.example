# Copy to .env.local and edit.

# Password the admin uses to log in.
ADMIN_PASSWORD=summer2026

# Random secret used to sign the admin session cookie.
ADMIN_SECRET=change-me-to-a-long-random-string

# --- Storage ---
# If these are set, the app uses Upstash Redis (works on Vercel).
# If not set, the app falls back to a local data/db.json file (good for local dev).
# Vercel auto-injects KV_REST_API_URL / KV_REST_API_TOKEN when you add a KV
# database from the Storage tab — no need to set these by hand on Vercel.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
